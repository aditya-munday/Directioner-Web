# ── Directioner — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# In Replit, set these as Secrets (padlock icon) — never commit real values.
# See SETUP.md for step-by-step instructions on getting each value.

# ── Supabase (required for auth + database) ───────────────────────────────────
# Supabase Dashboard → Settings → API

# Shared between frontend and API server (safe to expose — anon/public key)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API server only — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Dashboard → Settings → Database → Connection string (URI mode)
# Note: DATABASE_URL is runtime-managed on Replit — set it via the DB panel
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Razorpay (required for payment processing) ────────────────────────────────
# Razorpay Dashboard → Settings → API Keys
# Use rzp_test_* keys during development, rzp_live_* in production

# Safe to expose to the browser (public key)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# API server only — NEVER expose to the browser
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Frontend URL for CORS (comma-separated in production)
# Example: ALLOWED_ORIGIN=https://your-app.replit.app,https://your-domain.com
ALLOWED_ORIGIN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the API server, as seen by the browser
# In production: https://your-api-server.replit.app/api
# In Docker:     /api  (proxied through Nginx)
# In Replit dev: leave empty (Vite proxies /api → localhost:3001 if configured)
VITE_API_URL=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ── Docker local dev only ─────────────────────────────────────────────────────
# Password for the local postgres container (docker-compose up)
POSTGRES_PASSWORD=devpassword
