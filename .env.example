# ── Directioner — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# In Replit, set these as Secrets (not .env files) via the Secrets panel.

# ── Supabase (required for auth + realtime) ───────────────────────────────────
# Get these from your Supabase project → Settings → API

# Used by BOTH frontend (Vite exposes VITE_* vars) and API server
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Used by the API server ONLY — never expose to the frontend
# Get this from Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (required for the API server) ────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection string (URI mode)
# Or provision a Replit PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/database

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed CORS origins in production
# e.g. ALLOWED_ORIGIN=https://your-app.replit.app,https://your-custom-domain.com
ALLOWED_ORIGIN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# The frontend runs on port 5000 in development (managed by the workflow)
# No extra env vars needed for the frontend beyond VITE_SUPABASE_* above

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-in-production
